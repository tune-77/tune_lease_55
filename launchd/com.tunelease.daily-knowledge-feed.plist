<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tunelease.daily-knowledge-feed</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/kobayashiisaoryou/anaconda3/bin/python</string>
    <string>/Users/kobayashiisaoryou/clawd/tune_lease_55/daily_knowledge_feed.py</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONPATH</key>
    <string>/Users/kobayashiisaoryou/clawd/tune_lease_55</string>
    <key>PYTHONUNBUFFERED</key>
    <string>1</string>
    <key>PATH</key>
    <string>/Users/kobayashiisaoryou/anaconda3/bin:/Users/kobayashiisaoryou/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <!-- 毎月1日 6:00 に実行 -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Day</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>WorkingDirectory</key>
  <string>/Users/kobayashiisaoryou/clawd/tune_lease_55</string>

  <key>StandardOutPath</key>
  <string>/Users/kobayashiisaoryou/clawd/tune_lease_55/logs/daily_feed_stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/kobayashiisaoryou/clawd/tune_lease_55/logs/daily_feed_stderr.log</string>

  <!-- macOS がスリープ中だった場合、起動後に実行する -->
  <key>RunAtLoad</key>
  <false/>

  <!-- クラッシュしても再起動しない（日次バッチなので不要） -->
  <key>KeepAlive</key>
  <false/>
</dict>
</plist>
